# ==============================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ==============================================
# Points to your local backend running on your PC
# Update EXPO_PUBLIC_LOCAL_IP if your IP changes (run 'ipconfig')

# Your PC's local network IP
EXPO_PUBLIC_LOCAL_IP=172.19.1.35

# Web proxy URL - Metro dev server proxies /api/* to the real API (no separate process needed).
# Uses a relative path so the port doesn't need to be hardcoded.
EXPO_PUBLIC_API_PROXY_URL=/api/

# WebSocket URL - Test server
EXPO_PUBLIC_WSS_BASE_URL=wss://test-admin.happi.com.my/api/

# WebSocket URL - Your local IM service
EXPO_PUBLIC_WSS_BASE_URL=ws://172.19.1.35:9031/im/

# Image resources - Use test S3
EXPO_PUBLIC_IMG_BASE_URL=https://happi-app-res-test.s3.ap-southeast-5.amazonaws.com

# App URL for callbacks (local)
EXPO_PUBLIC_APP_URL=http://172.19.1.35:5173/service/

# Environment identifier
EXPO_PUBLIC_ENV=development

# Enable Mock OTP for local testing
EXPO_PUBLIC_ENABLE_MOCK_OTP=true
