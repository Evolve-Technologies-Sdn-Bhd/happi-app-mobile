# ==============================================
# PRODUCTION ENVIRONMENT
# ==============================================

# API Base URL - Production server
EXPO_PUBLIC_API_BASE_URL=https://test-admin.happi.com.my/api/

# WebSocket URL - Production server
EXPO_PUBLIC_WSS_BASE_URL=wss://test-admin.happi.com.my/api/

# Image resources - Production S3
EXPO_PUBLIC_IMG_BASE_URL=https://happi-app-res-test.s3.ap-southeast-5.amazonaws.com

# App URL for callbacks
EXPO_PUBLIC_APP_URL=https://test-admin.happi.com.my/service/

# Environment identifier
EXPO_PUBLIC_ENV=production

# Mock OTP ALWAYS disabled in production
EXPO_PUBLIC_ENABLE_MOCK_OTP=false
